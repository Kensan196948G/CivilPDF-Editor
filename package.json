{
  "name": "civilpdf-editor",
  "version": "0.1.0",
  "description": "建設・土木業向け高機能PDFエディター（電子印鑑・OCR・大判図面対応）",
  "main": "./out/main/index.js",
  "author": "CivilPDF-DX",
  "license": "UNLICENSED",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "lint": "eslint .",
    "test": "vitest run",
    "package": "electron-vite build && electron-builder",
    "package:win": "electron-vite build && electron-builder --win nsis msi",
    "package:mac": "electron-vite build && electron-builder --mac dmg pkg"
  },
  "dependencies": {
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^4.7.76"
  },
  "devDependencies": {
    "@eslint/js": "^9.14.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "electron": "^42.4.1",
    "electron-builder": "^26.0.12",
    "electron-vite": "^2.3.0",
    "eslint": "^9.14.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "jsdom": "^25.0.1",
    "typescript-eslint": "^8.13.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vitest": "^2.1.5"
  }
}
