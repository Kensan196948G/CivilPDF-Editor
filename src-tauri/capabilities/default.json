{
  "$schema": "https://schema.tauri.app/capability/2",
  "identifier": "default",
  "description": "CivilPDF Editor default capabilities",
  "platforms": ["linux", "macOS", "windows"],
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:menu:default",
    "core:webview:allow-print",
    "core:window:allow-set-title",
    "dialog:allow-open",
    "dialog:allow-save",
    "dialog:allow-confirm",
    {
      "identifier": "fs:allow-read-file",
      "allow": [
        { "path": "$DOCUMENT/**" },
        { "path": "$DOWNLOAD/**" },
        { "path": "$DESKTOP/**" },
        { "path": "$TEMP/**" }
      ]
    },
    {
      "identifier": "fs:allow-write-file",
      "allow": [
        { "path": "$DOCUMENT/**" },
        { "path": "$DOWNLOAD/**" },
        { "path": "$DESKTOP/**" },
        { "path": "$TEMP/**" }
      ]
    }
  ]
}
