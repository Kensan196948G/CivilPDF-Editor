{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CivilPDF Editor",
  "version": "1.2.3",
  "identifier": "jp.co.civilpdf.editor",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "CivilPDF Editor",
        "width": 1280,
        "height": 860
      }
    ],
    "security": {
      "csp": "default-src 'self' tauri: https://tauri.localhost; script-src 'self' 'unsafe-eval' 'wasm-unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; worker-src 'self' blob:; connect-src 'self' https://tauri.localhost http://localhost:*"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
